[node name="Label2" type="Label" parent="-----" unique_id=1409179899]
layout_mode = 0
offset_left = 641.0
offset_top = 393.0
offset_right = 2213.0
offset_bottom = 1560.0
text = "   [TeamTypes]
　　…………
　　39=08DA125C-G												; 注册ID
　　…………

　　[08DA125C-G]									  				;     注册ID
　　Name=Allied Anti-Nuke Team - 1					;     名称（注释用）
　　Script=0A6E54EC-G											;     指定注册在[ScriptTypes]里的脚本
　　TaskForce=0617909C-G									;     指定注册在[TaskForces]里的特遣部队

　　Priority=5														;     优先级  范围0~50，相同条件下越低越优先制造。写0疑似会无视Suicide=yes，建议写0以上。
　　Max=1															;     同时最多存在的小队数量
　　IsBaseDefense=no											;     是否守家

　　Aggressive=no												;     侵略性的，电脑在防御达到一定数量之后再开始建造该小队      ;进攻性小队，写yes时出完守家部队之后才出。据说和Suicide共同起作用。(待确认)
　　Suicide=yes													;     自毁式攻击，受到攻击不允许还击      ;是否还击，写yes则小队移动时不会攻击射程内的敌人，也不会还击，只严格执行脚本。据说和Aggressive共同起作用。(待确认)
　　-Annoyance=no												; !   烦恼效果，作用不明      挨揍时还手【一次】然后继续执行任务，优先级低于Aggressive和Suicide，具体效果待测试。

　　AvoidThreats=yes											;     规避威胁，小队成员在移动的过程中将会试图规避途中可能遭遇的敌方单位      是否会按威胁计算方法寻找最小威胁路径。

　　Autocreate=yes												; !   自动建造      结合地图预置单位生效。遭遇战中，在条件满足的情况下，平均每隔AutocreateTime规定的时间，制造一队带有Autocreate的小队。
　　-Reinforce=no													; ! x 增援部队      ;写yes会强制补充该小队中损失的成员。
　　AreTeamMembersRecruitable=no					;     小队成员是否允许重组      ;队伍成员可否被调去更高优先级的队伍中。
　　Recruiter=no													;     强制重组优先级较低的小队的成员，如果它们是可以重组的
　　Prebuild=no													; !   预先建造，作用不明      可能会在不需要时提前造好该队伍。(待确认)

　　MindControlDecision=0									; !   遭心控后，0=自动，1=加入控制方，2=进入回收厂，3=进入发电厂，4=搜索敌人，5=什么也不做


　　Loadable=no													; !   可装载      运载单位写yes会计算ContentScan。      是否有运载单位。
　　Full=no															; ! x 创建小队成员的时候，如果小队中有运载工具，其他成员是否应该位于运载工具的内部
　　OnTransOnly=no											; !   只能运输，作用不明
        UseTransportOrigin=no									; !   使用原始的运载工具
　　Droppod=no													; ! x 使用空降舱进入战区
　　TransportsReturnOnUnload=yes					;     运载工具卸载后返回基地

　　Group=-1														; !   分组，等同于人类玩家按下Ctrl+数字键组建的小队      ;除非特殊需要。另：-2时会选取任何TaskForce。
　　House=<none>												; ! x 创建小队成员时的所属作战方
　　VeteranLevel=1												; ! x 兵种等级
　　TechLevel=0													; ! x 科技等级，疑似无效
　　IonImmune=no												; ! x 离子风暴免疫

　　OnlyTargetHouseEnemy=no							; !   只攻击敌方单位，作用不明      ;是否只针对敌对方。
　　-Whiner=yes													; !   哀叫效果，作用不明
　　-LooseRecruit=no											; !   解散新兵，作用不明
　　-GuardSlower=no											; !   降低反应速度，作用不明

"
tab_stops = PackedFloat32Array(20)

